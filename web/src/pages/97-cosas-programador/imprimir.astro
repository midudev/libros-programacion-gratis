---
import Layout from '../../layouts/Layout.astro';
import { sourceRepository } from '../../data/library';
import { programmer97ThingsAdvice, programmer97ThingsMeta } from '../../data/programmer97Things';
import { enhanceProgrammerAdviceHtml } from '../../data/programmer97ThingsReadability';
import { siteConfig } from '../../data/seo';

export const prerender = true;

const title = `${programmer97ThingsMeta.title} - PDF | ${siteConfig.name}`;
const description =
	'Versión imprimible en PDF de los 97 consejos de 97 cosas que todo programador debe saber, traducidos al español.';
const canonical = '/97-cosas-programador/imprimir/';
const externalLinkRel = 'nofollow noreferrer';
---

<Layout
	title={title}
	description={description}
	canonical={canonical}
	image={siteConfig.defaultImage}
	imageAlt={programmer97ThingsMeta.shortTitle}
	ogType="article"
	robots="noindex, follow"
>
	<main class="print-book" aria-labelledby="print-book-title">
		<section class="print-cover" aria-label="Portada">
			<p class="print-kicker">librosgratis.dev</p>
			<h1 id="print-book-title">{programmer97ThingsMeta.title}</h1>
			<p class="print-subtitle">
				{programmer97ThingsAdvice.length} consejos traducidos al español
			</p>
			<p class="print-meta">Editor original: {programmer97ThingsMeta.editor}</p>
		</section>

		<section class="print-license" aria-labelledby="print-license-title">
			<h2 id="print-license-title">Atribución y licencia</h2>
			<p>
				Traducción al español a partir de las contribuciones originales listadas en{' '}
				<a href={programmer97ThingsMeta.originalSourceUrl} target="_blank" rel={externalLinkRel}>
					Programmer 97-things
				</a>
				. La obra original indica: “{programmer97ThingsMeta.originalLicenseNotice}” (
				<a href={programmer97ThingsMeta.originalLicenseUrl} target="_blank" rel={externalLinkRel}>
					{programmer97ThingsMeta.originalLicenseName}
				</a>
				).
			</p>
			<p>
				Esta versión forma parte del repositorio{' '}
				<a href={sourceRepository.href} target="_blank" rel={externalLinkRel}>
					{sourceRepository.name}
				</a>
				.
			</p>
		</section>

		<nav class="print-toc" aria-labelledby="print-toc-title">
			<h2 id="print-toc-title">Índice</h2>
			<ol>
				{programmer97ThingsAdvice.map((advice) => (
					<li>
						<a href={`#${advice.slug}`}>
							<span>{advice.title}</span>
							<small>{advice.author}</small>
						</a>
					</li>
				))}
			</ol>
		</nav>

		<section class="print-advice-list" aria-label="Consejos">
			{programmer97ThingsAdvice.map((advice) => (
				<article class="print-advice" id={advice.slug}>
					<header class="print-advice-header">
						<p class="eyebrow">Consejo {advice.number} de {programmer97ThingsAdvice.length}</p>
						<h2>{advice.title}</h2>
						<p class="reader-author">
							Por {advice.author}
							{advice.translator && ` · Traducción: ${advice.translator}`}
						</p>
					</header>
					<div class="advice-content print-advice-content" set:html={enhanceProgrammerAdviceHtml(advice.contentHtml)} />
				</article>
			))}
		</section>
	</main>
</Layout>

<style is:global>
	.print-book {
		width: min(100%, 920px);
		margin: 0 auto;
		padding: 4rem 2rem;
		color: var(--text);
	}

	.print-cover {
		display: grid;
		align-content: center;
		min-height: 86vh;
		padding: 4rem 0;
		border-bottom: 1px solid var(--border);
	}

	.print-kicker,
	.print-meta {
		margin: 0;
		color: var(--muted);
		font-size: 0.88rem;
		font-weight: 800;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.print-cover h1 {
		max-width: 11ch;
		margin: 1rem 0;
		font-family: 'Instrument Serif', serif;
		font-size: clamp(4rem, 11vw, 8rem);
		font-weight: 400;
		line-height: 0.92;
		letter-spacing: 0;
		text-wrap: balance;
	}

	.print-subtitle {
		margin: 0 0 2.5rem;
		max-width: 40ch;
		color: var(--muted);
		font-size: 1.25rem;
		line-height: 1.45;
	}

	.print-license,
	.print-toc {
		padding: 3rem 0;
		border-bottom: 1px solid var(--border);
	}

	.print-license h2,
	.print-toc h2,
	.print-advice-header h2 {
		margin: 0;
		font-family: 'Instrument Serif', serif;
		font-weight: 400;
		letter-spacing: 0;
		text-wrap: balance;
	}

	.print-license h2,
	.print-toc h2 {
		font-size: clamp(2rem, 5vw, 3.5rem);
	}

	.print-license p {
		max-width: 72ch;
		color: color-mix(in srgb, var(--text) 82%, transparent);
		font-size: 1rem;
		line-height: 1.7;
	}

	.print-license a,
	.print-toc a {
		color: var(--accent);
		text-underline-offset: 3px;
	}

	.print-toc ol {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
		gap: 0.5rem 1rem;
		margin: 1.5rem 0 0;
		padding-left: 1.3rem;
	}

	.print-toc li {
		padding-left: 0.2rem;
	}

	.print-toc a {
		display: grid;
		gap: 0.08rem;
		text-decoration: none;
	}

	.print-toc span {
		font-weight: 760;
		line-height: 1.25;
	}

	.print-toc small {
		color: var(--muted);
		font-size: 0.78rem;
	}

	.print-advice {
		max-width: 820px;
		margin: 0 auto;
		padding: 3.2rem 0;
	}

	.print-advice + .print-advice {
		border-top: 1px solid var(--border);
	}

	.print-advice-header {
		display: grid;
		gap: 0.35rem;
		padding-bottom: 1rem;
		border-bottom: 1px solid var(--border);
	}

	.print-advice-header h2 {
		max-width: 16ch;
		font-size: clamp(2.4rem, 6vw, 4.8rem);
		line-height: 0.98;
	}

	@media print {
		@page {
			size: A4;
			margin: 18mm 16mm;
		}

		html,
		body {
			background: #fff;
		}

		.print-book {
			width: auto;
			margin: 0;
			padding: 0;
		}

		.print-cover {
			min-height: 0;
			height: 240mm;
			padding: 0;
			border: 0;
			break-after: page;
		}

		.print-cover h1 {
			font-size: 54pt;
		}

		.print-subtitle {
			font-size: 14pt;
		}

		.print-license,
		.print-toc {
			padding: 0;
			border: 0;
			break-after: page;
		}

		.print-license h2,
		.print-toc h2 {
			font-size: 28pt;
		}

		.print-license p {
			font-size: 10.5pt;
		}

		.print-toc ol {
			grid-template-columns: repeat(2, minmax(0, 1fr));
			gap: 0.28rem 0.85rem;
			font-size: 8.4pt;
		}

		.print-toc small {
			font-size: 7.5pt;
		}

		.print-advice {
			max-width: none;
			padding: 0;
			break-before: page;
		}

		.print-advice + .print-advice {
			border: 0;
		}

		.print-advice-header {
			border-color: #ddd4c8;
			break-after: avoid;
		}

		.print-advice-header h2 {
			max-width: 18ch;
			font-size: 30pt;
		}

		.print-advice-content {
			font-size: 10.1pt;
			line-height: 1.52;
		}

		.print-advice-content p,
		.print-advice-content ul,
		.print-advice-content ol,
		.print-advice-content blockquote,
		.print-advice-content pre,
		.print-advice-content table {
			margin: 0.72rem 0;
		}

		.print-advice-content blockquote,
		.print-advice-content pre,
		.print-advice-content table {
			break-inside: avoid;
		}

		.print-advice-content blockquote {
			font-size: 14pt;
		}

		.print-advice-content pre {
			white-space: pre-wrap;
			background: #f5f1ea;
			color: #1a1a1a;
		}

		a {
			color: inherit;
			text-decoration: none;
		}
	}
</style>
