---
import Layout from '../../layouts/Layout.astro';
import { sourceRepository } from '../../data/library';
import {
	programmer97ThingsAdvice,
	programmer97ThingsMeta,
	type ProgrammerAdvice,
} from '../../data/programmer97Things';
import { siteConfig } from '../../data/seo';

export const prerender = true;

export function getStaticPaths() {
	return programmer97ThingsAdvice.map((advice, index) => ({
		params: { slug: advice.slug },
		props: { advice, index },
	}));
}

const { advice, index } = Astro.props as { advice: ProgrammerAdvice; index: number };
const previousAdvice = programmer97ThingsAdvice[index - 1];
const nextAdvice = programmer97ThingsAdvice[index + 1];
const canonical = `/97-cosas-programador/${advice.slug}/`;
const title = `${advice.title} | ${programmer97ThingsMeta.shortTitle}`;
const description = advice.excerpt;
const externalLinkRel = 'nofollow noreferrer';
const structuredData = {
	'@context': 'https://schema.org',
	'@graph': [
		{
			'@type': 'BreadcrumbList',
			itemListElement: [
				{
					'@type': 'ListItem',
					position: 1,
					name: 'Libros gratis de programación',
					item: siteConfig.url,
				},
				{
					'@type': 'ListItem',
					position: 2,
					name: programmer97ThingsMeta.shortTitle,
					item: new URL('/97-cosas-programador/', siteConfig.url).toString(),
				},
				{
					'@type': 'ListItem',
					position: 3,
					name: advice.title,
					item: new URL(canonical, siteConfig.url).toString(),
				},
			],
		},
		{
			'@type': 'Article',
			headline: advice.title,
			description,
			author: {
				'@type': 'Person',
				name: advice.author,
			},
			translator: advice.translator
				? {
						'@type': 'Person',
						name: advice.translator,
					}
				: undefined,
			isPartOf: {
				'@type': 'Book',
				name: programmer97ThingsMeta.title,
				editor: {
					'@type': 'Person',
					name: programmer97ThingsMeta.editor,
				},
			},
			inLanguage: 'es',
			isAccessibleForFree: true,
			license: programmer97ThingsMeta.originalLicenseUrl,
			isBasedOn: advice.originalUrl ?? programmer97ThingsMeta.originalSourceUrl,
			position: advice.number,
			url: new URL(canonical, siteConfig.url).toString(),
		},
	],
};
---

<Layout
	title={title}
	description={description}
	canonical={canonical}
	structuredData={structuredData}
	image={siteConfig.defaultImage}
	imageAlt={advice.title}
	ogType="article"
>
	<div class="page advice-page">
		<header class="header">
			<a class="logo" href="/" aria-label="Inicio">
				<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
					<path d="M5 5a1 1 0 0 1 1 -1h2a1 1 0 0 1 1 1v14a1 1 0 0 1 -1 1h-2a1 1 0 0 1 -1 -1l0 -14" />
					<path d="M9 5a1 1 0 0 1 1 -1h2a1 1 0 0 1 1 1v14a1 1 0 0 1 -1 1h-2a1 1 0 0 1 -1 -1l0 -14" />
					<path d="M5 8h4" /><path d="M9 16h4" />
					<path d="M13.803 4.56l2.184 -.53c.562 -.135 1.133 .19 1.282 .732l3.695 13.418a1.02 1.02 0 0 1 -.634 1.219l-.133 .041l-2.184 .53c-.562 .135 -1.133 -.19 -1.282 -.732l-3.695 -13.418a1.02 1.02 0 0 1 .634 -1.219l.133 -.041" />
					<path d="M14 9l4 -1" /><path d="M16 16l3.923 -.98" />
				</svg>
			</a>
			<nav class="header-nav" aria-label="Principal">
				<a class="header-link" href="/">
					<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<path d="M4 19a2 2 0 0 0 2 2h12" />
						<path d="M6 17a2 2 0 0 0 -2 2v-14a2 2 0 0 1 2 -2h12v18" />
						<path d="M8 7h6" />
					</svg>
					<span>Biblioteca</span>
				</a>
				<a class="header-link" href={sourceRepository.href} target="_blank" rel={externalLinkRel}>
					<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<path d="M9 19c-4.3 1.4 -4.3 -2.5 -6 -3" />
						<path d="M15 21v-3.5c0 -1 .1 -1.4 -.5 -2c2.8 -.3 5.5 -1.4 5.5 -6a4.6 4.6 0 0 0 -1.3 -3.2a4.2 4.2 0 0 0 -.1 -3.2s-1.1 -.3 -3.5 1.3a12.3 12.3 0 0 0 -6.2 0c-2.4 -1.6 -3.5 -1.3 -3.5 -1.3a4.2 4.2 0 0 0 -.1 3.2a4.6 4.6 0 0 0 -1.3 3.2c0 4.6 2.7 5.7 5.5 6c-.6 .6 -.6 1.2 -.5 2v3.5" />
					</svg>
					<span>GitHub</span>
				</a>
			</nav>
		</header>

		<main>
			<nav class="breadcrumbs" aria-label="Migas de pan">
				<a href="/">Libros gratis de programación</a>
				<span aria-hidden="true">/</span>
				<a href="/97-cosas-programador/">{programmer97ThingsMeta.shortTitle}</a>
				<span aria-hidden="true">/</span>
				<span>{advice.title}</span>
			</nav>

			<article class="advice-article">
				<header class="advice-article-header">
					<p class="eyebrow">Consejo {advice.number} de {programmer97ThingsAdvice.length}</p>
					<h1>{advice.title}</h1>
					<p class="reader-author">Por {advice.author}</p>
				</header>

				<div class="advice-content" set:html={advice.contentHtml} />

				<footer class="advice-attribution">
					<p>
						Traducción al español a partir de
						{advice.originalUrl ? (
							<>
								{' la '}
								<a href={advice.originalUrl} target="_blank" rel={externalLinkRel}>
									contribución original
								</a>
							</>
						) : (
							<>
								{' las contribuciones originales listadas en '}
								<a href={programmer97ThingsMeta.originalSourceUrl} target="_blank" rel={externalLinkRel}>
									Programmer 97-things
								</a>
							</>
						)}
						. La obra original indica: “{programmer97ThingsMeta.originalLicenseNotice}” (
						<a href={programmer97ThingsMeta.originalLicenseUrl} target="_blank" rel={externalLinkRel}>
							{programmer97ThingsMeta.originalLicenseName}
						</a>
						).
					</p>
				</footer>
			</article>

			<nav class="advice-pagination" aria-label="Navegación entre consejos">
				{previousAdvice ? (
					<a href={`/97-cosas-programador/${previousAdvice.slug}/`} rel="prev">
						<small>Anterior</small>
						<span>{previousAdvice.title}</span>
					</a>
				) : (
					<span aria-hidden="true"></span>
				)}
				<a class="advice-pagination-index" href="/97-cosas-programador/">
					<small>Índice</small>
					<span>Los 97 consejos</span>
				</a>
				{nextAdvice ? (
					<a href={`/97-cosas-programador/${nextAdvice.slug}/`} rel="next">
						<small>Siguiente</small>
						<span>{nextAdvice.title}</span>
					</a>
				) : (
					<span aria-hidden="true"></span>
				)}
			</nav>
		</main>

		<footer class="footer">
			<p>
				<a href="/">Volver a la biblioteca</a> · Contenido del repositorio{' '}
				<a href={sourceRepository.href} target="_blank" rel={externalLinkRel}>
					{sourceRepository.name}
				</a>
			</p>
		</footer>
	</div>
</Layout>
