---
import Layout from '../layouts/Layout.astro';
import {
	getLocalPdfBook,
	librarySections,
	sourceRepository,
	totalBooks,
} from '../data/library';
import {
	createHomeStructuredData,
	getSectionPageEntry,
	getSectionPagePath,
	siteConfig,
} from '../data/seo';
import { sectionLogoSources } from '../data/sectionLogos';

const title = 'Libros gratis de programación en español — librosgratis.dev';
const description =
	'Encuentra libros y guías gratuitas de programación en español. JavaScript, TypeScript, Python, Rust, React, Git, SQL y más.';
const keywords = [
	'libros de programación gratis',
	'libros gratis programación español',
	'ebooks programación español',
	'javascript gratis',
	'typescript gratis',
	'python gratis',
	'libros desarrollo web',
];

const sectionEntries = librarySections.map(getSectionPageEntry);

const externalLinkRel = 'nofollow noreferrer';
const isExternalHref = (href: string) => /^https?:\/\//.test(href);
const bookLinkRel = (href: string) =>
	isExternalHref(href) ? externalLinkRel : undefined;

const structuredData = createHomeStructuredData();
---

<Layout
	title={title}
	description={description}
	keywords={keywords}
	structuredData={structuredData}
	canonical="/"
	image={siteConfig.defaultImage}
>
	<div class="page">
		<header class="header">
			<a class="logo" href="/" aria-label="Inicio">
				<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
					<path d="M5 5a1 1 0 0 1 1 -1h2a1 1 0 0 1 1 1v14a1 1 0 0 1 -1 1h-2a1 1 0 0 1 -1 -1l0 -14" />
					<path d="M9 5a1 1 0 0 1 1 -1h2a1 1 0 0 1 1 1v14a1 1 0 0 1 -1 1h-2a1 1 0 0 1 -1 -1l0 -14" />
					<path d="M5 8h4" /><path d="M9 16h4" />
					<path d="M13.803 4.56l2.184 -.53c.562 -.135 1.133 .19 1.282 .732l3.695 13.418a1.02 1.02 0 0 1 -.634 1.219l-.133 .041l-2.184 .53c-.562 .135 -1.133 -.19 -1.282 -.732l-3.695 -13.418a1.02 1.02 0 0 1 .634 -1.219l.133 -.041" />
					<path d="M14 9l4 -1" /><path d="M16 16l3.923 -.98" />
				</svg>
			</a>
			<nav class="header-nav" aria-label="Principal">
				<a class="header-link" href="#" id="show-favorites" aria-label="Ver libros favoritos">
					<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
					</svg>
					<span>Favoritos</span>
					<span class="favorites-count" id="favorites-count">0</span>
				</a>
				<a class="header-link" href={sourceRepository.href} target="_blank" rel={externalLinkRel}>
					<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<path d="M9 19c-4.3 1.4 -4.3 -2.5 -6 -3" />
						<path d="M15 21v-3.5c0 -1 .1 -1.4 -.5 -2c2.8 -.3 5.5 -1.4 5.5 -6a4.6 4.6 0 0 0 -1.3 -3.2a4.2 4.2 0 0 0 -.1 -3.2s-1.1 -.3 -3.5 1.3a12.3 12.3 0 0 0 -6.2 0c-2.4 -1.6 -3.5 -1.3 -3.5 -1.3a4.2 4.2 0 0 0 -.1 3.2a4.6 4.6 0 0 0 -1.3 3.2c0 4.6 2.7 5.7 5.5 6c-.6 .6 -.6 1.2 -.5 2v3.5" />
					</svg>
					<span>GitHub</span>
				</a>
				<a class="header-cta" href="/contribuir/">
					<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<path d="M5 19.5v-14a2.5 2.5 0 0 1 2.5 -2.5h10.5v18h-10.5a2.5 2.5 0 0 1 0 -5h10.5" />
						<path d="M9 8h5" />
						<path d="M9 11h4" />
					</svg>
					<span>Enviar libro</span>
				</a>
			</nav>
		</header>

		<main>
			<section class="hero">
				<h1>Libros <em>gratis</em> de programación en español</h1>
				<p class="hero-sub">
					{totalBooks} recursos gratuitos sobre JavaScript, TypeScript, Python,
					Rust, React, Git, SQL y más.
				</p>
			</section>

			<section class="library" id="biblioteca" aria-labelledby="library-title">
				<h2 id="library-title" class="sr-only">Biblioteca</h2>

				<div class="toolbar">
					<nav class="language-dock" aria-label="Ir a tema">
						{
							sectionEntries.map((entry) => {
								const logoSources = sectionLogoSources(entry.section.slug);

								return (
									<a
										class:list={['language-dock-link', logoSources.length > 1 && 'is-logo-pair']}
										href={`#${entry.section.slug}`}
										aria-label={`Ir a ${entry.section.title}`}
										title={entry.section.title}
									>
										<span class="language-dock-logo-stack" aria-hidden="true">
											{logoSources.map((logo) => (
												<img
													src={logo}
													alt=""
													width="28"
													height="28"
													loading="lazy"
												/>
											))}
										</span>
									</a>
								);
							})
						}
					</nav>

					<label class="search-control" for="library-search">
						<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<path d="M10 18a8 8 0 1 1 5.657 -13.657A8 8 0 0 1 10 18z" />
							<path d="M21 21l-5.35 -5.35" />
						</svg>
						<input
							id="library-search"
							class="search-input"
							type="search"
							placeholder="Buscar por título, autor, lenguaje o tema..."
							autocomplete="off"
						/>
					</label>

					<div class="results-bar" aria-live="polite">
						<span><strong data-results-count>{totalBooks}</strong> resultados</span>
						<button class="reset-btn" type="button" data-reset-search hidden>
							Limpiar búsqueda
						</button>
					</div>
				</div>

				{
					sectionEntries.map((entry) => {
						const section = entry.section;

						return (
							<section
								class="topic"
								id={section.slug}
								data-group={section.group}
								data-section={section.title}
								aria-labelledby={`${section.slug}-title`}
							>
								<div class="topic-header">
									<h2 id={`${section.slug}-title`}>
										<span class="topic-logo-stack" aria-hidden="true">
											{sectionLogoSources(section.slug).map((logo) => (
												<img
													class="topic-logo"
													src={logo}
													alt=""
													width="22"
													height="22"
													loading="lazy"
												/>
											))}
										</span>
										{section.title}
										<a
											class="topic-title-link"
											href={getSectionPagePath(entry)}
											aria-label={`Ver libros gratis de ${entry.displayName}`}
											title={`Libros gratis de ${entry.displayName}`}
										>
											<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
												<path d="M7 17L17 7" />
												<path d="M8 7h9v9" />
											</svg>
										</a>
									</h2>
									<span class="topic-count">
										{section.books.length} {section.books.length === 1 ? 'libro' : 'libros'}
									</span>
								</div>
								<p class="topic-desc">{section.description}</p>

								<div class="book-grid">
									{section.books.map((book) => {
										const pdfBook = getLocalPdfBook(book);
										const hasHtmlVersion = pdfBook && pdfBook.href !== pdfBook.pdfHref;
										const bookHref = hasHtmlVersion ? book.href : (pdfBook?.readerPath ?? book.href);
										const opensInNewTab = isExternalHref(bookHref);

										return (
										<article
											class:list={['book', pdfBook && 'is-pdf']}
											data-search={`${book.title} ${book.author ?? ''} ${section.title} ${section.group}`.toLowerCase()}
										>
												{(pdfBook || opensInNewTab) && (
													<a
														class="book-card-link"
														href={bookHref}
														target={opensInNewTab ? '_blank' : undefined}
														rel={bookLinkRel(bookHref)}
														aria-hidden="true"
														tabindex="-1"
													></a>
												)}
												<h3>
													{book.title}
												</h3>
												{book.author && <p class="book-author">{book.author}</p>}
												{book.formats && book.formats.length > 0 && (
													<div class="book-formats">
														{book.formats.map((format) => (
															<span>{format}</span>
														))}
													</div>
												)}
												{book.note && <p class="book-note">{book.note}</p>}
												{(pdfBook || opensInNewTab) && (
													<div class="book-actions" aria-label={`Acciones para ${book.title}`}>
														{hasHtmlVersion && (
															<a
																class="book-action book-primary-action"
																href={book.href}
																target={isExternalHref(book.href) ? '_blank' : undefined}
																rel={bookLinkRel(book.href)}
																aria-label={`Ver HTML de ${book.title}`}
															>
																<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
																	<path d="M4 19a2 2 0 0 0 2 2h12" />
																	<path d="M6 17a2 2 0 0 0 -2 2v-14a2 2 0 0 1 2 -2h12v18" />
																	<path d="M8 7h6" />
																</svg>
																<span>Ver HTML</span>
															</a>
														)}
														{pdfBook ? (
															<>
																<a
																	class:list={['book-action', !hasHtmlVersion && 'book-primary-action']}
																	href={pdfBook.readerPath}
																	aria-label={`Ver PDF de ${book.title}`}
																>
																	<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
																		<path d="M14 3v4a1 1 0 0 0 1 1h4" />
																		<path d="M17 21h-10a2 2 0 0 1 -2 -2v-14a2 2 0 0 1 2 -2h7l5 5v11a2 2 0 0 1 -2 2z" />
																		<path d="M9 15h6" />
																		<path d="M9 18h3" />
																	</svg>
																	<span>Ver PDF</span>
																</a>
																<a
																	class="book-action"
																	href={pdfBook.downloadPath}
																	aria-label={`Descargar ${book.title}`}
																>
																	<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
																		<path d="M12 3v12" />
																		<path d="M7 10l5 5l5 -5" />
																		<path d="M5 21h14" />
																	</svg>
																	<span>Descargar</span>
																</a>
															</>
														) : (
															<a
																class="book-action book-primary-action"
																href={bookHref}
																target="_blank"
																rel={bookLinkRel(bookHref)}
																aria-label={`Visitar sitio web de ${book.title}`}
															>
																<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
																	<path d="M7 17L17 7" />
																	<path d="M8 7h9v9" />
																</svg>
																<span>Visitar Sitio Web</span>
															</a>
														)}
														<button
															class="book-action"
															data-favorite="false"
															data-book-id={book.id}
															aria-label="Marcar como favorito"
														>
													<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" 
														 stroke="currentColor" stroke-width="1.9" stroke-linecap="round" 
														 stroke-linejoin="round" aria-hidden="true">
														<path fill="none" d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
													</svg>
														</button>
													</div>
												)}
											</article>
										);
									})}
								</div>
							</section>
						);
					})
				}

				<div class="empty-state" hidden data-empty-state>
					<p>No hay coincidencias con esa búsqueda. Prueba con otro término.</p>
				</div>
			</section>

			<div class="favorites-panel" id="favorites-panel" hidden>
				<div class="favorites-header">
					<h2>Libros Favoritos</h2>
					<button class="favorites-close" type="button" aria-label="Cerrar panel de favoritos">
						<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<path d="M18 6L6 18" />
							<path d="M6 6l12 12" />
						</svg>
					</button>
				</div>
				<div class="favorites-list" id="favorites-list">
					<p class="favorites-empty" hidden>No tienes libros favoritos aún. Haz clic en el corazón de cualquier libro para agregarlo.</p>
				</div>
			</div>
		</main>

		<footer class="footer">
			<nav class="footer-topic-links" aria-label="Páginas de libros por tema">
				{
					sectionEntries.map((entry) => (
						<a href={getSectionPagePath(entry)}>Libros gratis de {entry.displayName}</a>
					))
				}
			</nav>
			<div class="footer-meta">
				<p>
					Contenido del repositorio{' '}
					<a href={sourceRepository.href} target="_blank" rel={externalLinkRel}>
						{sourceRepository.name}
					</a>
				</p>
				<button class="footer-share" type="button" data-share-trigger>Compartir</button>
			</div>
		</footer>
	</div>

	<script is:inline>
		const searchInput = document.querySelector('#library-search');
		const resetButton = document.querySelector('[data-reset-search]');
		const resultsCount = document.querySelector('[data-results-count]');
		const emptyState = document.querySelector('[data-empty-state]');
		const sectionBlocks = Array.from(document.querySelectorAll('.topic'));
		const shareButtons = Array.from(document.querySelectorAll('[data-share-trigger]'));

		const applyFilters = () => {
			const query = (searchInput?.value ?? '').trim().toLowerCase();
			let visibleBooks = 0;

			sectionBlocks.forEach((section) => {
				let sectionVisibleBooks = 0;

				section.querySelectorAll('.book').forEach((card) => {
					const haystack = card.getAttribute('data-search') ?? '';
					const matchesSearch = query === '' || haystack.includes(query);

					card.toggleAttribute('hidden', !matchesSearch);
					if (matchesSearch) {
						sectionVisibleBooks += 1;
						visibleBooks += 1;
					}
				});

				section.toggleAttribute('hidden', sectionVisibleBooks === 0);
			});

			if (resultsCount) {
				resultsCount.textContent = String(visibleBooks);
			}

			if (emptyState) {
				emptyState.toggleAttribute('hidden', visibleBooks !== 0);
			}

			if (resetButton) {
				resetButton.toggleAttribute('hidden', query === '');
			}
		};

		searchInput?.addEventListener('input', applyFilters);

		resetButton?.addEventListener('click', () => {
			if (searchInput) {
				searchInput.value = '';
				searchInput.focus();
			}
			applyFilters();
		});

		shareButtons.forEach((button) => {
			button.dataset.label = button.textContent?.trim() ?? 'Compartir';

			button.addEventListener('click', async () => {
				const shareData = {
					title: document.title,
					text: 'Libros gratis de programación en español, organizados por tema.',
					url: window.location.href,
				};

				try {
					if (navigator.share) {
						await navigator.share(shareData);
						return;
					}

					await navigator.clipboard.writeText(shareData.url);
					button.textContent = 'Enlace copiado';
					window.setTimeout(() => {
						button.textContent = button.dataset.label ?? 'Compartir';
					}, 1800);
				} catch (error) {
					console.error(error);
				}
			});
		});

		applyFilters();
	</script>
	<script>
		import { getFavorites, toggleFavorite } from '../scripts/favorites.ts';

		const showFavoritesBtn = document.querySelector('#show-favorites');
		const favoritesPanel = document.querySelector('#favorites-panel');
		const favoritesList = document.querySelector('#favorites-list');
		const favoritesEmpty = favoritesPanel?.querySelector('.favorites-empty');
		const favoritesClose = favoritesPanel?.querySelector('.favorites-close');
		const favoritesCount = document.querySelector('#favorites-count');

		const updateFavoritesCount = () => {
			if (!favoritesCount) return;
			const count = getFavorites().length;
			favoritesCount.textContent = count.toString();
			favoritesCount.setAttribute('data-count', count.toString());
		};

		const bookLookup = new Map();
		document.querySelectorAll('.book').forEach((card) => {
			const favBtn = card.querySelector('[data-book-id]');
			if (!favBtn) return;
			const bookId = favBtn.getAttribute('data-book-id');
			if (!bookId) return;
			const title = card.querySelector('h3')?.textContent?.trim() ?? '';
			const author = card.querySelector('.book-author')?.textContent?.trim() ?? '';
			const cardLink = card.querySelector('.book-card-link');
			const href = cardLink?.getAttribute('href') ?? '';
			bookLookup.set(bookId, { title, author, href });
		});

		const syncFavoritesUI = () => {
			const favs = getFavorites();
			document.querySelectorAll('[data-favorite]').forEach((btn) => {
				const bookId = btn.getAttribute('data-book-id');
				if (!bookId) return;
				const isFav = favs.includes(bookId);
				btn.setAttribute('data-favorite', isFav.toString());
				btn.setAttribute('aria-label', isFav ? 'Quitar de favoritos' : 'Marcar como favorito');
			});
		};

		const renderFavoritesPanel = () => {
			if (!favoritesList || !favoritesEmpty) return;
			const favorites = getFavorites();

			while (favoritesList.children.length > 1) {
				favoritesList.lastChild?.remove();
			}
			favoritesList.innerHTML = '';
			favoritesList.appendChild(favoritesEmpty);

			if (favorites.length === 0) {
				favoritesEmpty.removeAttribute('hidden');
				return;
			}

			favoritesEmpty.setAttribute('hidden', '');

			favorites.forEach((bookId) => {
				const book = bookLookup.get(bookId);
				if (!book) return;

				const isExternal = book.href && /^https?:\/\//.test(book.href);
				const item = document.createElement('div');
				item.className = 'favorites-item';
				item.innerHTML = [
					'<div style="flex:1">',
					book.href
						? `<a class="favorites-item-title" href="${book.href}" ${isExternal ? 'target="_blank" rel="nofollow noreferrer"' : ''}>${book.title}</a>`
						: `<h3 class="favorites-item-title">${book.title}</h3>`,
					book.author ? `<p class="favorites-item-author">${book.author}</p>` : '',
					'</div>',
					`<button class="favorites-item-remove" data-book-id="${bookId}" aria-label="Quitar ${book.title} de favoritos">`,
					'<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">',
					'<path d="M18 6L6 18" /><path d="M6 6l12 12" />',
					'</svg>',
					'</button>',
				].join('');
				favoritesList.appendChild(item);
			});

			favoritesList.querySelectorAll('.favorites-item-remove').forEach((removeBtn) => {
				removeBtn.addEventListener('click', (e) => {
					e.stopPropagation();
					const bookId = removeBtn.getAttribute('data-book-id');
					if (!bookId) return;
					toggleFavorite(bookId);
					syncFavoritesUI();
					updateFavoritesCount();
					renderFavoritesPanel();
				});
			});
		};

		syncFavoritesUI();
		updateFavoritesCount();

		document.querySelectorAll('[data-favorite]').forEach((btn) => {
			btn.addEventListener('click', (e) => {
				e.preventDefault();
				e.stopPropagation();
				const bookId = btn.getAttribute('data-book-id');
				if (!bookId) return;
				const wasFavorited = toggleFavorite(bookId);
				btn.setAttribute('data-favorite', wasFavorited.toString());
				btn.setAttribute('aria-label', wasFavorited ? 'Quitar de favoritos' : 'Marcar como favorito');
				updateFavoritesCount();
				if (favoritesPanel && !favoritesPanel.hasAttribute('hidden')) {
					renderFavoritesPanel();
				}
			});
		});

		showFavoritesBtn?.addEventListener('click', () => {
			favoritesPanel?.removeAttribute('hidden');
			renderFavoritesPanel();
		});
		favoritesClose?.addEventListener('click', () => {
			favoritesPanel?.setAttribute('hidden', '');
		});
		document.addEventListener('keydown', (e) => {
			if (e.key === 'Escape' && favoritesPanel && !favoritesPanel.hasAttribute('hidden')) {
				favoritesPanel.setAttribute('hidden', '');
			}
		});
		document.addEventListener('favorites-changed', () => {
			syncFavoritesUI();
			updateFavoritesCount();
			if (favoritesPanel && !favoritesPanel.hasAttribute('hidden')) {
				renderFavoritesPanel();
			}
		});
	</script>
</Layout>
