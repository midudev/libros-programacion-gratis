---
import Layout from '../../layouts/Layout.astro';
import { getLocalPdfBook, sourceRepository } from '../../data/library';
import { sectionLogoSources } from '../../data/sectionLogos';
import {
	createSectionStructuredData,
	getSectionCanonicalUrl,
	getSectionMetaDescription,
	getSectionMetaTitle,
	getSectionPagePath,
	getSectionPageTitle,
	sectionPageEntries,
	siteConfig,
	type SectionPageEntry,
} from '../../data/seo';

export const prerender = true;

export function getStaticPaths() {
	return sectionPageEntries.map((entry) => ({
		params: { slug: entry.pathSlug },
		props: { entry },
	}));
}

const { entry } = Astro.props as { entry: SectionPageEntry };
const { section } = entry;

const title = getSectionMetaTitle(entry);
const pageHeading = getSectionPageTitle(entry);
const description = getSectionMetaDescription(entry);
const structuredData = createSectionStructuredData(entry);
const canonical = getSectionCanonicalUrl(entry);
const formats = Array.from(new Set(section.books.flatMap((book) => book.formats ?? [])));
const formatsLabel = formats.length > 0 ? formats.join(', ') : 'recursos web';
const highlightedBooks = section.books.slice(0, 3).map((book) => book.title);
const highlightedBooksSentence =
	highlightedBooks.length > 0
		? `Para empezar, puedes revisar ${highlightedBooks.join(', ')}${
				section.books.length > highlightedBooks.length ? ' y el resto de recursos de la lista.' : '.'
			}`
		: '';
const heroLogoSources = sectionLogoSources(section.slug);
const relatedEntries = sectionPageEntries
	.filter((related) => related.section.group === section.group && related.section.slug !== section.slug)
	.slice(0, 4);

const externalLinkRel = 'nofollow noreferrer';
const isExternalHref = (href: string) => /^https?:\/\//.test(href);
const bookLinkRel = (href: string) =>
	isExternalHref(href) ? externalLinkRel : undefined;
---

<Layout
	title={title}
	description={description}
	keywords={entry.focusKeywords}
	structuredData={structuredData}
	canonical={canonical}
	image={siteConfig.defaultImage}
	imageAlt={pageHeading}
>
	<div class="page">
		<header class="header">
			<a class="logo" href="/" aria-label="Inicio">
				<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
					<path d="M5 5a1 1 0 0 1 1 -1h2a1 1 0 0 1 1 1v14a1 1 0 0 1 -1 1h-2a1 1 0 0 1 -1 -1l0 -14" />
					<path d="M9 5a1 1 0 0 1 1 -1h2a1 1 0 0 1 1 1v14a1 1 0 0 1 -1 1h-2a1 1 0 0 1 -1 -1l0 -14" />
					<path d="M5 8h4" /><path d="M9 16h4" />
					<path d="M13.803 4.56l2.184 -.53c.562 -.135 1.133 .19 1.282 .732l3.695 13.418a1.02 1.02 0 0 1 -.634 1.219l-.133 .041l-2.184 .53c-.562 .135 -1.133 -.19 -1.282 -.732l-3.695 -13.418a1.02 1.02 0 0 1 .634 -1.219l.133 -.041" />
					<path d="M14 9l4 -1" /><path d="M16 16l3.923 -.98" />
				</svg>
			</a>
			<nav class="header-nav" aria-label="Principal">
				<a class="header-link" href="/">
					<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<path d="M4 19a2 2 0 0 0 2 2h12" />
						<path d="M6 17a2 2 0 0 0 -2 2v-14a2 2 0 0 1 2 -2h12v18" />
						<path d="M8 7h6" />
					</svg>
					<span>Biblioteca</span>
				</a>
				<a class="header-link" href={sourceRepository.href} target="_blank" rel={externalLinkRel}>
					<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<path d="M9 19c-4.3 1.4 -4.3 -2.5 -6 -3" />
						<path d="M15 21v-3.5c0 -1 .1 -1.4 -.5 -2c2.8 -.3 5.5 -1.4 5.5 -6a4.6 4.6 0 0 0 -1.3 -3.2a4.2 4.2 0 0 0 -.1 -3.2s-1.1 -.3 -3.5 1.3a12.3 12.3 0 0 0 -6.2 0c-2.4 -1.6 -3.5 -1.3 -3.5 -1.3a4.2 4.2 0 0 0 -.1 3.2a4.6 4.6 0 0 0 -1.3 3.2c0 4.6 2.7 5.7 5.5 6c-.6 .6 -.6 1.2 -.5 2v3.5" />
					</svg>
					<span>GitHub</span>
				</a>
			</nav>
		</header>

		<main>
			<nav class="breadcrumbs" aria-label="Migas de pan">
				<a href="/">Libros gratis de programación</a>
				<span aria-hidden="true">/</span>
				<span>{entry.displayName}</span>
			</nav>

			<section class="hero topic-page-hero">
				<div class="topic-page-hero-copy">
					<p class="eyebrow">{section.group}</p>
					<h1>{pageHeading}</h1>
					<p class="hero-sub text-wrap">{entry.intro}</p>
					<div class="topic-page-stats" aria-label="Resumen de la colección">
						<span><strong>{section.books.length}</strong> {section.books.length === 1 ? 'libro' : 'libros'}</span>
						<span><strong>{formatsLabel}</strong></span>
					</div>
				</div>
				{heroLogoSources.length > 0 && (
					<div
						class={`topic-page-hero-logos ${heroLogoSources.length > 1 ? 'is-logo-pair' : ''}`}
						aria-hidden="true"
					>
						{heroLogoSources.map((logo) => (
							<img
								src={logo}
								alt=""
								width="180"
								height="180"
								loading="eager"
								decoding="async"
							/>
						))}
					</div>
				)}
			</section>

			<section class="seo-copy" aria-labelledby="about-topic-title">
				<h2 id="about-topic-title">Aprender {entry.displayName} con recursos gratuitos</h2>
				<p>
					Esta página reúne libros y guías de {entry.displayName} en español para estudiar
					{` ${section.description.toLowerCase()}.`} La colección combina recursos en formatos
					{` ${formatsLabel}`} y se actualiza desde la biblioteca principal de librosgratis.dev.
				</p>
				{highlightedBooks.length > 0 && (
					<p>
						{highlightedBooksSentence}
					</p>
				)}
			</section>

			<section class="topic topic-page-list" aria-labelledby="books-title">
				<div class="topic-header">
					<h2 id="books-title">Libros y guías de {entry.displayName}</h2>
					<span class="topic-count">
						{section.books.length} {section.books.length === 1 ? 'recurso' : 'recursos'}
					</span>
				</div>
				<p class="topic-desc">{description}</p>

				<div class="book-grid">
					{section.books.map((book) => {
						const pdfBook = getLocalPdfBook(book);
						const hasHtmlVersion = pdfBook && pdfBook.href !== pdfBook.pdfHref;
						const bookHref = hasHtmlVersion ? book.href : (pdfBook?.readerPath ?? book.href);
						const opensInNewTab = isExternalHref(bookHref);

						return (
							<article class:list={['book', pdfBook && 'is-pdf']}>
								{(pdfBook || opensInNewTab) && (
									<a
										class="book-card-link"
										href={bookHref}
										target={opensInNewTab ? '_blank' : undefined}
										rel={bookLinkRel(bookHref)}
										aria-hidden="true"
										tabindex="-1"
									></a>
								)}
								<h3>
									{book.title}
								</h3>
								{book.author && <p class="book-author">{book.author}</p>}
								{book.formats && book.formats.length > 0 && (
									<div class="book-formats">
										{book.formats.map((format) => (
											<span>{format}</span>
										))}
									</div>
								)}
								{book.note && <p class="book-note">{book.note}</p>}
								{(pdfBook || opensInNewTab) && (
									<div class="book-actions" aria-label={`Acciones para ${book.title}`}>
										{hasHtmlVersion && (
											<a
												class="book-action book-primary-action"
												href={book.href}
												target={isExternalHref(book.href) ? '_blank' : undefined}
												rel={bookLinkRel(book.href)}
												aria-label={`Ver HTML de ${book.title}`}
											>
												<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
													<path d="M4 19a2 2 0 0 0 2 2h12" />
													<path d="M6 17a2 2 0 0 0 -2 2v-14a2 2 0 0 1 2 -2h12v18" />
													<path d="M8 7h6" />
												</svg>
												<span>Ver HTML</span>
											</a>
										)}
										{pdfBook ? (
											<>
												<a
													class:list={['book-action', !hasHtmlVersion && 'book-primary-action']}
													href={pdfBook.readerPath}
													aria-label={`Ver PDF de ${book.title}`}
												>
													<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
														<path d="M14 3v4a1 1 0 0 0 1 1h4" />
														<path d="M17 21h-10a2 2 0 0 1 -2 -2v-14a2 2 0 0 1 2 -2h7l5 5v11a2 2 0 0 1 -2 2z" />
														<path d="M9 15h6" />
														<path d="M9 18h3" />
													</svg>
													<span>Ver PDF</span>
												</a>
												<a
													class="book-action"
													href={pdfBook.downloadPath}
													aria-label={`Descargar ${book.title}`}
												>
													<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
														<path d="M12 3v12" />
														<path d="M7 10l5 5l5 -5" />
														<path d="M5 21h14" />
													</svg>
													<span>Descargar</span>
												</a>
											</>
										) : (
											<a
												class="book-action book-primary-action"
												href={bookHref}
												target="_blank"
												rel={bookLinkRel(bookHref)}
												aria-label={`Visitar sitio web de ${book.title}`}
											>
												<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
													<path d="M7 17L17 7" />
													<path d="M8 7h9v9" />
												</svg>
												<span>Visitar Sitio Web</span>
											</a>
										)}
									</div>
								)}
							</article>
						);
					})}
				</div>
			</section>

			<section class="seo-faq" aria-labelledby="faq-title">
				<h2 id="faq-title">Preguntas frecuentes sobre {entry.displayName}</h2>
				<details>
					<summary>¿Dónde encontrar libros gratis de {entry.displayName} en español?</summary>
					<p>
						En esta página tienes una selección curada de libros gratis de {entry.displayName},
						con enlaces directos a recursos PDF, HTML o ebooks cuando están disponibles.
					</p>
				</details>
				<details>
					<summary>¿Estos libros de {entry.displayName} son realmente gratis?</summary>
					<p>
						Sí. La colección apunta a recursos gratuitos, abiertos o publicados por sus autores
						para consulta libre.
					</p>
				</details>
			</section>

			{relatedEntries.length > 0 && (
				<section class="related-topics" aria-labelledby="related-title">
					<h2 id="related-title">Más libros de {section.group.toLowerCase()}</h2>
					<div class="related-grid">
						{relatedEntries.map((related) => (
							<a href={getSectionPagePath(related)}>
								<span>{related.displayName}</span>
								<small>{related.section.books.length} {related.section.books.length === 1 ? 'libro' : 'libros'}</small>
							</a>
						))}
					</div>
				</section>
			)}
		</main>

		<footer class="footer">
			<p>
				<a href="/">Volver a la biblioteca</a> · Contenido del repositorio{' '}
				<a href={sourceRepository.href} target="_blank" rel={externalLinkRel}>
					{sourceRepository.name}
				</a>
			</p>
		</footer>
	</div>
</Layout>
