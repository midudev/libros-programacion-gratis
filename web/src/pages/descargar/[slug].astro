---
import Layout from '../../layouts/Layout.astro';
import { localPdfBooks, sourceRepository, type LocalPdfBook } from '../../data/library';
import { getSectionPageEntry, getSectionPagePath, siteConfig } from '../../data/seo';

export const prerender = true;

export function getStaticPaths() {
	return localPdfBooks.map((book) => ({
		params: { slug: book.bookSlug },
		props: { book },
	}));
}

const { book } = Astro.props as { book: LocalPdfBook };
const sectionEntry = getSectionPageEntry(book.section);
const waitSeconds = 8;
const title = `Descargar ${book.title} PDF | ${siteConfig.name}`;
const description = `Descarga gratis ${book.title} en PDF desde librosgratis.dev${book.author ? `, de ${book.author}` : ''}.`;
const externalLinkRel = 'nofollow noreferrer';
---

<Layout
	title={title}
	description={description}
	canonical={book.downloadPath}
	image={siteConfig.defaultImage}
	imageAlt={book.title}
	ogType="article"
	robots="noindex, follow"
>
	<div class="page download-page">
		<header class="header">
			<a class="logo" href="/" aria-label="Inicio">
				<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
					<path d="M5 5a1 1 0 0 1 1 -1h2a1 1 0 0 1 1 1v14a1 1 0 0 1 -1 1h-2a1 1 0 0 1 -1 -1l0 -14" />
					<path d="M9 5a1 1 0 0 1 1 -1h2a1 1 0 0 1 1 1v14a1 1 0 0 1 -1 1h-2a1 1 0 0 1 -1 -1l0 -14" />
					<path d="M5 8h4" /><path d="M9 16h4" />
					<path d="M13.803 4.56l2.184 -.53c.562 -.135 1.133 .19 1.282 .732l3.695 13.418a1.02 1.02 0 0 1 -.634 1.219l-.133 .041l-2.184 .53c-.562 .135 -1.133 -.19 -1.282 -.732l-3.695 -13.418a1.02 1.02 0 0 1 .634 -1.219l.133 -.041" />
					<path d="M14 9l4 -1" /><path d="M16 16l3.923 -.98" />
				</svg>
			</a>
			<nav class="header-nav" aria-label="Principal">
				<a class="header-link" href={book.readerPath}>
					<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<path d="M4 19a2 2 0 0 0 2 2h12" />
						<path d="M6 17a2 2 0 0 0 -2 2v-14a2 2 0 0 1 2 -2h12v18" />
						<path d="M8 7h6" />
					</svg>
					<span>Leer</span>
				</a>
				<a class="header-link" href="/">
					<span>Biblioteca</span>
				</a>
			</nav>
		</header>

		<main>
			<nav class="breadcrumbs" aria-label="Migas de pan">
				<a href="/">Libros gratis de programación</a>
				<span aria-hidden="true">/</span>
				<a href={getSectionPagePath(sectionEntry)}>{sectionEntry.displayName}</a>
				<span aria-hidden="true">/</span>
				<span>Descargar PDF</span>
			</nav>

			<section
				class="download-panel"
				aria-labelledby="download-title"
				data-download-gate
				data-download-url={book.pdfHref}
				data-download-name={book.fileName}
				data-wait-seconds={waitSeconds}
			>
				<div class="download-copy">
					<p class="eyebrow">Descarga preparada</p>
					<h1 id="download-title">{book.title}</h1>
					{book.author && <p class="reader-author">{book.author}</p>}
					<p class="download-note">
						La descarga se iniciará automáticamente cuando termine la espera. Si el navegador la bloquea, el botón quedará listo para hacerlo manualmente.
					</p>
				</div>

				<div class="download-timer" aria-live="polite">
					<span class="download-count" data-download-count>{waitSeconds}</span>
					<span class="download-count-label">segundos</span>
					<div class="download-progress" aria-hidden="true">
						<span data-download-progress></span>
					</div>
				</div>

				<div class="download-actions">
					<a
						class="reader-button reader-button-primary is-disabled"
						href={book.pdfHref}
						download={book.fileName}
						aria-disabled="true"
						data-download-link
					>
						<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<path d="M12 3v12" />
							<path d="M7 10l5 5l5 -5" />
							<path d="M5 21h14" />
						</svg>
						<span data-download-label>Preparando descarga</span>
					</a>
					<a class="reader-button" href={book.readerPath}>Volver al lector</a>
				</div>
			</section>
		</main>

		<footer class="footer">
			<p>
				Contenido del repositorio{' '}
				<a href={sourceRepository.href} target="_blank" rel={externalLinkRel}>
					{sourceRepository.name}
				</a>
			</p>
		</footer>
	</div>
</Layout>

<script>
	const gate = document.querySelector('[data-download-gate]');

	if (gate instanceof HTMLElement) {
		const downloadUrl = gate.getAttribute('data-download-url') ?? '';
		const downloadName = gate.getAttribute('data-download-name') ?? 'libro.pdf';
		const waitSeconds = Number(gate.getAttribute('data-wait-seconds') ?? '8');
		const counter = gate.querySelector('[data-download-count]');
		const progress = gate.querySelector('[data-download-progress]');
		const downloadLink = gate.querySelector('[data-download-link]');
		const label = gate.querySelector('[data-download-label]');
		let remaining = waitSeconds;
		let hasTriggered = false;

		const triggerDownload = () => {
			if (hasTriggered) return;

			hasTriggered = true;

			const temporaryLink = document.createElement('a');
			temporaryLink.href = downloadUrl;
			temporaryLink.download = downloadName;
			temporaryLink.style.display = 'none';
			document.body.append(temporaryLink);
			temporaryLink.click();
			temporaryLink.remove();
		};

		const unlock = () => {
			if (downloadLink instanceof HTMLAnchorElement) {
				downloadLink.classList.remove('is-disabled');
				downloadLink.removeAttribute('aria-disabled');
			}

			if (label instanceof HTMLElement) {
				label.textContent = 'Descargar ahora';
			}

			triggerDownload();
		};

		const paint = () => {
			if (counter instanceof HTMLElement) {
				counter.textContent = String(Math.max(remaining, 0));
			}

			if (progress instanceof HTMLElement) {
				const percent = ((waitSeconds - remaining) / waitSeconds) * 100;
				progress.style.width = `${Math.min(Math.max(percent, 0), 100)}%`;
			}
		};

		paint();

		const timer = window.setInterval(() => {
			remaining -= 1;
			paint();

			if (remaining <= 0) {
				window.clearInterval(timer);
				unlock();
			}
		}, 1000);

		downloadLink?.addEventListener('click', (event) => {
			if (remaining > 0) {
				event.preventDefault();
				return;
			}

			hasTriggered = true;
		});
	}
</script>
